```gitignore
# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.nuxt/
out/

# Logs
*.log

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
env/
ENV/

# Temporary files
*.tmp
*.temp
*.bak

# Testing
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# Package manager
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Distribution / packaging
*.tar.gz
*.whl
*.egg
*.egg-info/

# Local configuration
*.local
config/local.*

# Browsers
*.css.map
*.js.map

# TypeScript
*.tsbuildinfo
```